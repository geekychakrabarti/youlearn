# .gitignore for YouLearn

# Secrets and config (never commit these)
config.json
*.env

# Data
data/
exports/
videos/
*.db
*.sqlite

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# macOS
.DS_Store
.AppleDouble
*.icloud

# Session files
SESSION_CONTEXT.md
SESSION_NOTES.md
screenshots/
.playwright-mcp/

# Dev tools
docs/make_annotations.py

# App bundle (built, not source)
/Applications/YouLearn.app

# Node (if ever added)
node_modules/

# Logs
*.log
