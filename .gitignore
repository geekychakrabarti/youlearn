# .gitignore for YouLearn

# ── Secrets & config ──────────────────────────────
config.json          # contains API keys and personal paths
*.env

# ── Data (personal, large, or machine-specific) ───
data/
exports/
videos/
*.db
*.sqlite

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# ── Node (if ever added) ──────────────────────────
node_modules/

# ── macOS ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
*.icloud

# ── Session / development files ───────────────────
SESSION_CONTEXT.md
SESSION_NOTES.md
screenshots/
.playwright-mcp/

# ── App bundle (built, not committed) ─────────────
/Applications/YouLearn.app

# ── Logs ──────────────────────────────────────────
*.log
